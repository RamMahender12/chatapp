{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "openrouter_image": {
      "type": "local",
      "command": ["npx", "-y", "openrouter-image-mcp"],
      "enabled": true,
      "environment": {
        "OPENROUTER_API_KEY": "your-api-key-here",
        "OPENROUTER_MODEL": "google/gemini-2.5-flash-image"
      }
    }
  },
  "permission": {
    "external_directory": {
      "~/AppData/Local/Temp/opencode-vision/**": "allow",
      "~/.config/opencode/**": "allow"
    },
    "openrouter_image_analyze_image": {
      "*": "allow"
    }
  }
}
